{
  "name": "poe2-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "doctor": "bash pob/doctor.sh",
    "economy": "tsx src/economy/pull.ts",
    "prices": "tsx src/economy/query.ts",
    "trade": "tsx src/economy/trade.ts",
    "craft-sim": "tsx src/crafting-sim/magic-craft.ts",
    "boots-sim": "tsx src/crafting-sim/boots-craft.ts",
    "desecration-sim": "tsx src/crafting-sim/desecration-craft.ts",
    "jewel-sim": "tsx src/crafting-sim/jewel-craft.ts",
    "bow-sim": "tsx src/crafting-sim/bow-omen-slam-craft.ts",
    "api": "tsx watch src/server/server.ts",
    "dev": "DEV=1 concurrently -n api,web -c blue,green \"pnpm api\" \"vite --config app/vite.config.ts\"",
    "app": "pnpm dev",
    "app:build": "vite --config app/vite.config.ts build",
    "app:serve": "tsx src/server/server.ts",
    "reference": "tsx src/reference/pull-reference.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  }
}
